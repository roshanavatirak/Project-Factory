datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  phone             String?       @unique
  password          String
  name              String?
  role              String        @default("student")
  emailVerified     Boolean       @default(false)
  verificationToken String?       @unique
  resetToken        String?       @unique
  resetTokenExpires DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  projects          UserProject[]
}

model Project {
  id          String        @id @default(uuid())
  title       String
  category    String
  domain      String
  description String
  difficulty  String
  duration    String
  image       String
  features    String[]
  techStack   String[]
  price       String
  demoUrl     String?
  githubUrl   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       UserProject[]
}

model UserProject {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  progress  Int      @default(0)
  branch    String   @default("main")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId])
}

model Inquiry {
  id             String   @id @default(uuid())
  name           String
  email          String
  org            String?
  notes          String?
  domain         String
  complexity     String
  estimatedPrice Int
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Package {
  id            String   @id @default(uuid())
  key           String   @unique
  name          String
  description   String
  originalPrice Int
  standardPrice Int
  promoPrice    Int
  features      String[]
  popular       Boolean  @default(false)
  cta           String   @default("Acquire Package")
  glow          String   @default("none")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
